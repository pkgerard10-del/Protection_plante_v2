library(FactoMineR)
library(factoextra)
res_pca <- PCA(traitements[, c("dose_L_ha", "volume_bouillie_L_ha",
"efficacite_7j_pct", "efficacite_14j_pct",
"cout_fcfa_ha")],
scale.unit = TRUE, graph = FALSE)
fviz_pca_biplot(res_pca,
repel = TRUE,
col.var = "blue",
col.ind = "gray")
fviz_pca_biplot(res_pca,
repel = TRUE,
col.var = "blue",
col.ind = "black")
fviz_pca_biplot(res_pca,
repel = TRUE,
col.var = "blue",
col.ind = "gray")
fviz_pca_biplot(res_pca,
repel = TRUE,
col.var = "black",          # Visualisation
col.ind = "gray")
res_mca <- MCA(observations[, c("culture", "stade_phenologique",
"symptomes_observes", "conditions_meteo")],
graph = FALSE)
fviz_mca_biplot(res_mca,
repel = TRUE,             # Visualisation
col.var = "red",
col.ind = "gray")
donnees <- traitements[, c("dose_L_ha", "volume_bouillie_L_ha",
"efficacite_7j_pct", "efficacite_14j_pct", "cout_fcfa_ha")]
donnees_scaled <- scale(donnees)
dist_mat <- dist(donnees_scaled)
hc <- hclust(dist_mat, method = "ward.D2")
plot(hc, main = "Classification hiérarchique des traitements")
groups <- cutree(hc, k = 3)
table(groups)
donnees <- traitements[, c("dose_L_ha", "volume_bouillie_L_ha",
"efficacite_7j_pct", "efficacite_14j_pct",
"cout_fcfa_ha")]
res_pca <- PCA(donnees, scale.unit = TRUE, graph = FALSE)
fviz_pca_var(res_pca,
col.var = "steelblue",     # couleur des variables
repel = TRUE,              # évite le chevauchement des labels
title = "Cercle des corrélations - ACP")
fviz_pca_var(res_pca,
col.var = "green",     # couleur des variables
repel = TRUE,              # évite le chevauchement des labels
title = "Cercle des corrélations - ACP")
fviz_pca_var(res_pca,
col.var = "blue",     # couleur des variables
repel = TRUE,              # évite le chevauchement des labels
title = "Cercle des corrélations - ACP")
donnees <- traitements[, c("dose_L_ha", "volume_bouillie_L_ha",
"efficacite_7j_pct", "efficacite_14j_pct",
"cout_fcfa_ha")]
res_pca <- PCA(donnees, scale.unit = TRUE, graph = FALSE)
fviz_pca_var(res_pca,
col.var = "cos2",                     # couleur selon qualité de représentation
gradient.cols = c("red","yellow","green"), # dégradé de couleurs
repel = TRUE,                         # évite chevauchement des labels
title = "Cercle des corrélations - ACP")
fviz_pca_biplot(res_pca,
repel = TRUE,
col.var = "blue",
col.ind = "gray",
title = "Biplot ACP - traitements et variables")
